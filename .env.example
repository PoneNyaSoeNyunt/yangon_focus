APP_NAME="Yangon Focus"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-render-app-url.onrender.com
FRONTEND_URL=http://localhost:5173

LOG_CHANNEL=stack
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=
MYSQL_ATTR_SSL_CA=/var/www/html/ca.pem

SESSION_DRIVER=database
SESSION_LIFETIME=120

CACHE_STORE=database
QUEUE_CONNECTION=database

# Image storage: set to "public" for local dev, "cloudinary" for production
FILESYSTEM_DISK=public

CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# Frontend API base — used by Vite env
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Add this if you are using JWT for your React frontend
# JWT_SECRET=

# Mail - Keep as log for MVP testing
MAIL_MAILER=log