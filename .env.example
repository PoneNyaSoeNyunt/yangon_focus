APP_NAME="Yangon Focus"
APP_ENV=local
APP_KEY=base64:GENERATE_YOUR_OWN_KEY_HERE
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=yangon_focus
DB_USERNAME=root
DB_PASSWORD=

# Leave blank for local XAMPP/MariaDB setup
# MYSQL_ATTR_SSL_CA=

SESSION_DRIVER=database
SESSION_LIFETIME=120

CACHE_STORE=database
QUEUE_CONNECTION=database

# Image storage: set to "public" for local dev
FILESYSTEM_DISK=public

# Cloudinary is disabled for local evaluation to ensure zero-dependency runs
# CLOUDINARY_URL=

# Frontend API base — ensures React can reach the local PHP server
VITE_API_BASE_URL=http://localhost:8000/api/v1

# JWT Secret is required for authentication logic
JWT_SECRET=

# Mail - Redirects emails to local logs for testing without an SMTP server
MAIL_MAILER=log